# Veritabanı — geliştirme (SQLite, backend/.env bu dosyayı üst .env üzerine yazar)
DATABASE_URL=sqlite:///./data/arrow_license.db

# Postgres kullanıyorsanız startup'ta create_all için (varsayılan: false)
# INIT_DB_ON_STARTUP=false

# Üretim (PostgreSQL örneği)
# DATABASE_URL=postgresql+psycopg://arrow:arrow@localhost:5432/arrow_license

# JWT
JWT_SECRET_KEY=change-me-super-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS — virgülle ayrılmış veya *
CORS_ORIGINS=http://localhost:3000,https://license.arrowbilisim.com

# İlk süper admin (python -m app.seed_admin)
ADMIN_EMAIL=admin@arrowbilisim.com
ADMIN_PASSWORD=ChangeMe123!

# Demo plan varsayılan süre (gün)
DEMO_LICENSE_DAYS=7

# Arrow Restaurant süre uzatma talepleri (jsonl import)
# LICENSE_RENEW_JSONL_PATH=C:/arrowrestaurant/backend/data/license_renew_requests.jsonl
