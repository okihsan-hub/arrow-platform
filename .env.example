# --- PostgreSQL (docker-compose) ---
POSTGRES_DB=arrow_platform
POSTGRES_USER=arrow
POSTGRES_PASSWORD=arrow
POSTGRES_PORT=5432

# --- Backend ---
# SQLAlchemy will read DATABASE_URL. Use localhost when running backend locally.
DATABASE_URL=postgresql+psycopg://arrow:arrow@localhost:5432/arrow_platform

# JWT secrets must be long random strings in production.
JWT_SECRET_KEY=change-me-super-long-random-string
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# License activation request signing (HMAC-SHA256).
# Signature: HMAC_SHA256(LICENSE_SIGNING_SECRET, license_key + device_id + timestamp + nonce)
LICENSE_SIGNING_SECRET=change-me-long-random-string

# CORS (comma separated). Use * only in development if you must.
BACKEND_CORS_ORIGINS=http://localhost:3000

# Password hashing
BCRYPT_ROUNDS=12

# Optional: create an initial admin at first startup
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
